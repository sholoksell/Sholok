{
  "name": "sholok-customer-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npx kill-port 3000 8081 5000 2>nul & exit 0",
    "dev": "concurrently -n server,admin,web -c blue,magenta,green \"npm run server\" \"npm run admin\" \"vite --host\"",
    "dev:web": "vite --host",
    "server": "npm --prefix ecommerce_admin/server run dev",
    "server:start": "npm --prefix ecommerce_admin/server start",
    "server:install": "npm --prefix ecommerce_admin/server install",
    "admin": "npm --prefix ecommerce_admin run dev:web",
    "admin:install": "npm --prefix ecommerce_admin install",
    "install:all": "npm install && npm run server:install && npm run admin:install",
    "build": "vite build",
    "build:prod": "vite build --mode production && npm run analyze",
    "analyze": "vite-bundle-visualizer",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.546.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.49.2",
    "react-router-dom": "^6.20.0",
    "sonner": "^1.3.1",
    "swiper": "^11.0.5",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^3.4.18",
    "terser": "^5.46.0",
    "vite": "^7.1.7",
    "vite-plugin-compression": "^0.5.1"
  }
}
