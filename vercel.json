{
  "buildCommand": "node scripts/build-vercel.cjs",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/admin-api/:path*", "destination": "/api/admin-api" },
    { "source": "/admin-api", "destination": "/api/admin-api" },
    { "source": "/blog-api/:path*", "destination": "/api/blog-api" },
    { "source": "/blog-api", "destination": "/api/blog-api" },
    { "source": "/api/v1/:path*", "destination": "/api/multivendor-api" },
    { "source": "/jobportal-api/:path*", "destination": "/api/jobportal-api" },
    { "source": "/jobportal-api", "destination": "/api/jobportal-api" },
    { "source": "/tv-api/:path*", "destination": "/api/video-api" },
    { "source": "/tv-api", "destination": "/api/video-api" },
    { "source": "/api/:path((?!admin-api|blog-api|multivendor-api|jobportal-api|video-api).*)", "destination": "/api/admin-api" },
    { "source": "/shopping/admin/:path*", "destination": "/shopping/admin/index.html" },
    { "source": "/shopping/admin", "destination": "/shopping/admin/index.html" },
    { "source": "/shopping/:path*", "destination": "/shopping/index.html" },
    { "source": "/shopping", "destination": "/shopping/index.html" },
    { "source": "/blog/admin/:path*", "destination": "/blog/admin/index.html" },
    { "source": "/blog/admin", "destination": "/blog/admin/index.html" },
    { "source": "/blog/:path*", "destination": "/blog/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/news/:path*", "destination": "/news/index.html" },
    { "source": "/news", "destination": "/news/index.html" },
    { "source": "/smart-store/:path*", "destination": "/smart-store/index.html" },
    { "source": "/smart-store", "destination": "/smart-store/index.html" },
    { "source": "/job-portal/:path*", "destination": "/job-portal/index.html" },
    { "source": "/job-portal", "destination": "/job-portal/index.html" },
    { "source": "/home/admin/:path*", "destination": "/home/admin/index.html" },
    { "source": "/home/admin", "destination": "/home/admin/index.html" },
    { "source": "/VideoPlatform/:path*", "destination": "/VideoPlatform/index.html" },
    { "source": "/VideoPlatform", "destination": "/VideoPlatform/index.html" },
    { "source": "/tv/:path*", "destination": "/VideoPlatform/index.html" },
    { "source": "/tv", "destination": "/VideoPlatform/index.html" },
    { "source": "/webtoon/:path*", "destination": "/webtoon/index.html" },
    { "source": "/webtoon", "destination": "/webtoon/index.html" },
    { "source": "/:path((?!api|admin-api).*)", "destination": "/index.html" }
  ]
}
